# Copy to workers/ingest/.dev.vars (never commit .dev.vars)
# https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
# Coverage caps: baked in wrangler.jsonc (staging/production) — docs/21, docs/22, docs/23

# --- Secrets (required for Helix / EventSub) ---
# Production: wrangler secret put from workers/ingest — docs/15-ingest-runbook.md
ADMIN_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# EventSub webhook (Phase 1b) — required for POST /admin/twitch/eventsub/sync
# transport.secret: minimum 10 characters, maximum 100 (ASCII). NOT the Twitch client_secret.
# If the value contains $, wrap in single quotes in .dev.vars (e.g. TWITCH_EVENTSUB_SECRET='abc$xyz') — unquoted $ is expanded by the shell/dotenv parser.
TWITCH_EVENTSUB_SECRET=
# Public HTTPS :443 — e.g. cloudflared tunnel + /webhooks/twitch/eventsub
TWITCH_EVENTSUB_CALLBACK_URL=

# --- Kick (Phase 3) — register at https://dev.kick.com/ (ADR-003) ---
# Omit until credentials exist; poll_kick_tracked no-ops with NEEDS_API.
# KICK_CLIENT_ID=
# KICK_CLIENT_SECRET=
# KICK_MAX_TRACKED=800
# KICK_MIN_VIEWERS=2
# KICK_WEBHOOK_PUBLIC_KEY=   # PEM from GET /public/v1/public-key — POST /webhooks/kick/events

# --- YouTube (Phase 3) — Google Cloud YouTube Data API v3 (docs/05) ---
# Omit until API key exists; poll_youtube_tracked no-ops with NEEDS_API.
# YOUTUBE_API_KEY=
# YOUTUBE_MAX_TRACKED=80
# YOUTUBE_MIN_VIEWERS=2

# --- Optional local overrides (omit for wrangler auto-defaults) ---
# INGEST_COVERAGE_MODE=shards_only
# LIVE_SWEEP_MAX_PAGES=3
# GAME_PASS_GAMES_PER_CYCLE=2
# TWITCH_MAX_TRACKED=200
# TWITCH_MIN_VIEWERS=20
# SAMPLE_ARCHIVE_ENABLED=0
# TWITCH_RANKING_MIN_AIRTIME_MINUTES=1
# D1_META_LOG=1
# SAMPLE_ARCHIVE_ENABLED=1
# SAMPLE_ARCHIVE_MIN_ROWS=10
# COLD_ARCHIVE_ENABLED=1   # Parquet archive on rollup_daily prune — docs/11 R2 patterns
# INGEST_RATE_LIMIT_PER_MINUTE=60
# INGEST_RATE_LIMIT_DISABLED=1
# ALLOW_DEV_SEED=1
