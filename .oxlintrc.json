{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc"],
	"categories": {
		"correctness": "error"
	},
	"rules": {
		"eqeqeq": ["warn", "smart"],
		"no-console": "warn",
		"no-debugger": "error",
		"no-unused-vars": "error",
		"no-unreachable": "error",
		"no-dupe-keys": "error",
		"no-dupe-class-members": "error",
		"no-duplicate-case": "error",
		"typescript/no-explicit-any": "warn"
	},
	"env": {
		"builtin": true,
		"node": true
	},
	"ignorePatterns": [
		"**/node_modules/**",
		"**/.svelte-kit/**",
		"**/build/**",
		"**/dist/**",
		"**/.wrangler/**",
		"**/worker-configuration.d.ts",
		"**/*.tsbuildinfo"
	],
	"overrides": [
		{
			"files": ["**/*.test.ts", "**/*.spec.ts", "**/test/**"],
			"env": {
				"vitest": true
			},
			"rules": {
				"typescript/no-explicit-any": "off"
			}
		},
		{
			"files": ["scripts/**"],
			"rules": {
				"no-console": "off"
			}
		},
		{
			"files": ["workers/ingest/src/log.ts", "workers/ingest/src/db/d1-meta.ts"],
			"rules": {
				"no-console": "off"
			}
		}
	]
}
